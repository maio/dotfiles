set show-all-if-ambiguous on
set completion-ignore-case on
set bell-style none
$if Bash
    Space: magic-space
$endif

set convert-meta off
set input-meta on
set output-meta on

# "\ep": history-search-backward
# "\en": history-search-forward
# IJKL IDEA plugin emulation
"\ei": previous-history
"\ek": next-history
"\ej": backward-word
"\el": forward-word
"\eu": beginning-of-line
"\eo": end-of-line

